import React, { useState, useRef, useMemo } from 'react';
import { Camera, X, Upload } from 'lucide-react';
import { motion, AnimatePresence } from 'motion/react';
import { avaliarLocal } from '../lib/fastEval';

async function callIA({ content, search }: { content: any[], search: boolean }) {
  const headers = { "Content-Type": "application/json" };
  const body = { content, search };
  
  const r = await fetch("/api/triagem", {
    method: "POST",
    headers,
    body: JSON.stringify(body)
  });
  
  if (!r.ok) {
    let errMsg = "";
    try {
      const j = await r.json();
      errMsg = j.error || j.message || "";
    } catch {
      errMsg = await r.text().catch(() => "");
    }
    throw new Error(errMsg || "Erro na IA: " + r.status);
  }
  
  return await r.json();
}

